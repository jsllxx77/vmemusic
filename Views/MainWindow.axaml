<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VmeMusic.ViewModels"
        xmlns:models="using:VmeMusic.Models"
        xmlns:converters="using:VmeMusic.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="VmeMusic.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="VmeMusic"
        Width="1180"
        Height="760"
        MinWidth="940"
        MinHeight="620">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <converters:CoverArtConverter x:Key="CoverArtConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Background="#101214">
        <Border Grid.Row="0" Background="#181B1F" Padding="18,14">
            <Grid ColumnDefinitions="*,320,Auto,Auto" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding ServerProfileName, TargetNullValue=No server selected}"
                               Foreground="#F3F5F7"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ServerUrl}"
                               Foreground="#8E98A7"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBox Grid.Column="1"
                         PlaceholderText="Search songs"
                         Text="{Binding SearchQuery}" />
                <Button Grid.Column="2"
                        Content="Search"
                        Command="{Binding SearchCommand}" />
                <Button Grid.Column="3"
                        Content="Settings"
                        Command="{Binding OpenSettingsCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="190,*,300">
            <Border Grid.Column="0" Background="#15181B" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="VmeMusic"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7" />
                    <TextBlock Text="Search"
                               Margin="0,24,0,0"
                               Foreground="#F3F5F7"
                               FontWeight="SemiBold" />
                    <Button Content="Search songs"
                            Command="{Binding SearchCommand}" />
                    <Button Content="Newest albums"
                            Command="{Binding LoadNewestAlbumsCommand}" />
                    <Button Content="Artists"
                            Command="{Binding LoadArtistsCommand}" />
                    <Button Content="Playlists"
                            Command="{Binding LoadPlaylistsCommand}" />
                    <Button Content="Settings"
                            Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#101214" Padding="18">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding ContentTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7"
                               Margin="0,0,0,12" />

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedSong}"
                                 DoubleTapped="SongsList_OnDoubleTapped"
                                 IsVisible="{Binding IsSongsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Grid ColumnDefinitions="56,*,170,170,70" Margin="0,6">
                                        <Border Grid.Column="0"
                                                Width="42"
                                                Height="42"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Artist}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Album}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DurationText}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Albums}"
                                 SelectedItem="{Binding SelectedAlbum}"
                                 DoubleTapped="AlbumsList_OnDoubleTapped"
                                 IsVisible="{Binding IsAlbumsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Album">
                                    <Grid ColumnDefinitions="64,*,180,70,70" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Artist}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Year}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding SongCount}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Artists}"
                                 SelectedItem="{Binding SelectedArtist}"
                                 DoubleTapped="ArtistsList_OnDoubleTapped"
                                 IsVisible="{Binding IsArtistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Artist">
                                    <Grid ColumnDefinitions="64,*,100" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="24">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AlbumCount}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Playlists}"
                                 SelectedItem="{Binding SelectedPlaylist}"
                                 DoubleTapped="PlaylistsList_OnDoubleTapped"
                                 IsVisible="{Binding IsPlaylistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Playlist">
                                    <Grid ColumnDefinitions="64,*,100,100" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SongCount}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DurationText}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid IsVisible="{Binding IsSettingsView}"
                              RowDefinitions="Auto,Auto,Auto,Auto,*"
                              RowSpacing="14">
                            <Border Background="#15181B" Padding="14" CornerRadius="6">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                                    <TextBlock Text="Connection"
                                               Foreground="#F3F5F7"
                                               FontWeight="SemiBold" />
                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="180,*,160,160"
                                          ColumnSpacing="10"
                                          RowDefinitions="Auto,Auto">
                                        <TextBox Grid.Column="0"
                                                 Grid.Row="0"
                                                 PlaceholderText="Profile name"
                                                 Text="{Binding ServerProfileName}" />
                                        <TextBox Grid.Column="1"
                                                 Grid.Row="0"
                                                 PlaceholderText="Server URL"
                                                 Text="{Binding ServerUrl}" />
                                        <TextBox Grid.Column="2"
                                                 Grid.Row="0"
                                                 PlaceholderText="Username"
                                                 Text="{Binding Username}" />
                                        <TextBox Grid.Column="3"
                                                 Grid.Row="0"
                                                 PlaceholderText="Password"
                                                 PasswordChar="*"
                                                 Text="{Binding Password}" />
                                        <TextBlock Grid.Column="0"
                                                   Grid.Row="1"
                                                   Grid.ColumnSpan="4"
                                                   Text="Use Test before Save if you want to verify the server first."
                                                   Foreground="#8E98A7"
                                                   FontSize="12" />
                                    </Grid>
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Save Server"
                                                Command="{Binding SaveCurrentServerCommand}" />
                                        <Button Content="Test Connection"
                                                Command="{Binding TestConnectionCommand}" />
                                        <Button Content="Clear All Saved Data"
                                                Command="{Binding ClearSavedConnectionCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="Cache"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F5F7" />

                            <Border Grid.Row="2" Background="#15181B" Padding="14" CornerRadius="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Cover Art Cache"
                                                   Foreground="#F3F5F7"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CoverArtCacheDirectory}"
                                                   Foreground="#B8C0CC"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Clear Cache"
                                            Command="{Binding ClearCoverArtCacheCommand}"
                                            VerticalAlignment="Top" />
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="3"
                                       Text="Saved Servers"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F5F7" />

                            <Grid Grid.Row="4"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <ListBox ItemsSource="{Binding SavedServers}"
                                         SelectedItem="{Binding SelectedSavedServer}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:SavedServerProfile">
                                            <StackPanel Margin="0,6">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="#F3F5F7" />
                                                <TextBlock Text="{Binding ServerUrl}"
                                                           Foreground="#8E98A7"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Column="1"
                                        Content="Use"
                                        Command="{Binding UseSelectedServerCommand}"
                                        VerticalAlignment="Top" />
                                <Button Grid.Column="2"
                                        Content="Remove"
                                        Command="{Binding RemoveSelectedServerCommand}"
                                        VerticalAlignment="Top" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#15181B" Padding="18">
                <Grid RowDefinitions="Auto,Auto,Auto,196,Auto,*">
                    <TextBlock Text="Now Playing"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding CurrentSong.Title, FallbackValue=Nothing playing}"
                               Foreground="#F3F5F7"
                               FontSize="16"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding CurrentSong.Artist}"
                               Foreground="#9CA3AF"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                    <Border Grid.Row="3"
                            Width="180"
                            Height="180"
                            HorizontalAlignment="Left"
                            Background="#242A30"
                            CornerRadius="6"
                            Margin="0,20,0,8">
                        <Image Source="{Binding CurrentSong.CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                               Stretch="UniformToFill" />
                    </Border>
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,4,0,10">
                        <TextBlock Grid.Column="0"
                                   Text="Queue"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F5F7"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Remove"
                                Command="{Binding RemoveSelectedFromQueueCommand}" />
                        <Button Grid.Column="2"
                                Content="Clear"
                                Command="{Binding ClearQueueCommand}" />
                    </Grid>
                    <ListBox Grid.Row="5"
                             ItemsSource="{Binding PlaybackQueue}"
                             SelectedItem="{Binding SelectedSong}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <StackPanel Margin="0,5">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#F3F5F7"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Artist}"
                                               Foreground="#8E98A7"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#181B1F" Padding="18,12">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,2*,Auto,Auto,120" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#B8C0CC"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1"
                        Content="Prev"
                        Command="{Binding PlayPreviousCommand}" />
                <Button Grid.Column="2"
                        Content="Play"
                        Command="{Binding PlaySelectedCommand}" />
                <Button Grid.Column="3"
                        Content="Pause"
                        Command="{Binding TogglePlaybackCommand}" />
                <Button Grid.Column="4"
                        Content="Stop"
                        Command="{Binding StopCommand}" />
                <Button Grid.Column="5"
                        Content="Next"
                        Command="{Binding PlayNextCommand}" />
                <Slider Grid.Column="6"
                        Minimum="0"
                        Maximum="{Binding PlaybackDuration}"
                        Value="{Binding PlaybackPosition}"
                        IsEnabled="{Binding CanSeek}"
                        VerticalAlignment="Center" />
                <TextBlock Grid.Column="7"
                           Text="{Binding PlaybackPositionText}"
                           Foreground="#B8C0CC"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="8"
                           Text="{Binding PlaybackDurationText}"
                           Foreground="#8E98A7"
                           VerticalAlignment="Center" />
                <Slider Grid.Column="9"
                        Minimum="0"
                        Maximum="100"
                        Value="{Binding Volume}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>

</Window>
