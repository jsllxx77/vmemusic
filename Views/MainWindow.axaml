<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:VmeMusic.ViewModels"
                 xmlns:models="using:VmeMusic.Models"
                 xmlns:converters="using:VmeMusic.Converters"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 d:DesignWidth="1360"
                 d:DesignHeight="860"
                 x:Class="VmeMusic.Views.MainWindow"
                 x:DataType="vm:MainWindowViewModel"
                 Title="VmeMusic"
                 Width="1360"
                 Height="860"
                 MinWidth="1120"
                 MinHeight="720"
                 BackgroundStyle="Gradient"
                 CanPin="False"
                 ShowTitlebarBackground="False">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <suki:SukiWindow.Resources>
        <converters:CoverArtConverter x:Key="CoverArtConverter" />
    </suki:SukiWindow.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Background="#0F1118">
        <Border Grid.Row="0" Margin="20,14,20,12" Padding="18,14" Background="#14FFFFFF" CornerRadius="18">
            <Grid ColumnDefinitions="280,*,Auto" ColumnSpacing="14">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding ActiveServerName}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#FFF8F9FB"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ActiveServerUrl}"
                               Foreground="#B8C2D2"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Grid.Column="1" Background="#1AFFFFFF" CornerRadius="16" Padding="14,8">
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             PlaceholderText="搜索歌曲"
                             Text="{Binding SearchQuery}"
                             IsEnabled="{Binding HasActiveServer}" />
                </Border>

                <Button Grid.Column="2"
                        Content="搜索"
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding HasActiveServer}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,16" ColumnDefinitions="220,*,320" ColumnSpacing="18">
            <Border Grid.Column="0" Background="#14FFFFFF" CornerRadius="24" Padding="18,20">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Text="VmeMusic"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#FFF7F8FB" />
                        <TextBlock Text="Navidrome 桌面播放器"
                                   Foreground="#B8C2D2"
                                   FontSize="12" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,26,0,0" Spacing="8">
                        <Button Content="首页"
                                Command="{Binding OpenHomeCommand}"
                                IsEnabled="{Binding HasActiveServer}" />
                        <Button Content="搜索"
                                Command="{Binding SearchCommand}"
                                IsEnabled="{Binding HasActiveServer}" />
                        <Button Content="专辑"
                                Command="{Binding LoadNewestAlbumsCommand}"
                                IsEnabled="{Binding HasActiveServer}" />
                        <Button Content="艺术家"
                                Command="{Binding LoadArtistsCommand}"
                                IsEnabled="{Binding HasActiveServer}" />
                        <Button Content="播放列表"
                                Command="{Binding LoadPlaylistsCommand}"
                                IsEnabled="{Binding HasActiveServer}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Margin="0,18,0,18"
                            Padding="16"
                            Background="#12FFFFFF"
                            CornerRadius="18"
                            IsVisible="{Binding HasActiveServer}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="快捷入口"
                                       Foreground="#FFF7F8FB"
                                       FontWeight="SemiBold" />
                            <Button Content="正在播放"
                                    Command="{Binding OpenNowPlayingDetailsCommand}" />
                            <Button Content="最近播放"
                                    Command="{Binding ShowRecentSidebarCommand}" />
                            <Button Content="播放队列"
                                    Command="{Binding ShowQueueSidebarCommand}" />
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="3"
                            Content="设置"
                            HorizontalAlignment="Stretch"
                            Command="{Binding OpenSettingsCommand}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#11FFFFFF" CornerRadius="26" Padding="22">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{Binding ContentTitle}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FFF7F8FB" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#AEBACE"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer IsVisible="{Binding IsHomeView}">
                            <StackPanel Spacing="26">
                                <Border Background="#16FFFFFF" CornerRadius="22" Padding="22">
                                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="20">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="发现你的音乐库"
                                                       FontSize="34"
                                                       FontWeight="Bold"
                                                       Foreground="#FFF8F9FB" />
                                            <TextBlock Text="从首页快速进入最新专辑和播放列表，也可以直接搜索歌曲开始播放。"
                                                       Foreground="#C6CFDB"
                                                       FontSize="14"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#22FF4D67" CornerRadius="20" Padding="18">
                                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="播放列表"
                                                           Foreground="#FFF8F9FB"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="点击底栏歌曲可打开详情页，右侧可切换播放队列和最近播放。"
                                                           Foreground="#FFE5EAF0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="最新专辑"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF7F8FB" />
                                    <ListBox ItemsSource="{Binding HomeAlbums}"
                                             SelectedItem="{Binding SelectedAlbum}"
                                             DoubleTapped="AlbumsList_OnDoubleTapped"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="14" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Album">
                                                <Border Width="188" Padding="12" Background="#16FFFFFF" CornerRadius="18" Margin="0,0,0,6">
                                                    <StackPanel Spacing="10">
                                                        <Border Height="164" Background="#1DFFFFFF" CornerRadius="14">
                                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#FFF7F8FB"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Artist}"
                                                                   Foreground="#AEBACE"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="播放列表"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF7F8FB" />
                                    <ListBox ItemsSource="{Binding HomePlaylists}"
                                             SelectedItem="{Binding SelectedPlaylist}"
                                             DoubleTapped="PlaylistsList_OnDoubleTapped"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Playlist">
                                                <Border Width="220" Margin="0,0,14,14" Padding="12" Background="#16FFFFFF" CornerRadius="18">
                                                    <Grid ColumnDefinitions="74,*" ColumnSpacing="12">
                                                        <Border Width="74" Height="74" Background="#1DFFFFFF" CornerRadius="14">
                                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="#FFF7F8FB"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding SongCount, StringFormat='{}{0} 首歌曲'}"
                                                                       Foreground="#AEBACE"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding DurationText}"
                                                                       Foreground="#8D98AA"
                                                                       FontSize="12" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ListBox ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedSong}"
                                 DoubleTapped="SongsList_OnDoubleTapped"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="{Binding IsSongsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Border Padding="12" Margin="0,0,0,10" Background="#16FFFFFF" CornerRadius="16">
                                        <Grid ColumnDefinitions="58,*,180,180,70" ColumnSpacing="12">
                                            <Border Grid.Column="0" Width="48" Height="48" Background="#1DFFFFFF" CornerRadius="12">
                                                <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#FFF7F8FB"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Artist}"
                                                           Foreground="#AEBACE"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Album}"
                                                       Foreground="#AEBACE"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Artist}"
                                                       Foreground="#8D98AA"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding DurationText}"
                                                       Foreground="#FFF7F8FB"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Albums}"
                                 SelectedItem="{Binding SelectedAlbum}"
                                 DoubleTapped="AlbumsList_OnDoubleTapped"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="{Binding IsAlbumsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Album">
                                    <Border Padding="12" Margin="0,0,0,10" Background="#16FFFFFF" CornerRadius="16">
                                        <Grid ColumnDefinitions="64,*,180,80,80" ColumnSpacing="12">
                                            <Border Grid.Column="0" Width="52" Height="52" Background="#1DFFFFFF" CornerRadius="14">
                                                <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#FFF7F8FB"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Artist}"
                                                           Foreground="#AEBACE"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Artist}"
                                                       Foreground="#AEBACE"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Year}"
                                                       Foreground="#8D98AA"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding SongCount}"
                                                       Foreground="#FFF7F8FB"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Artists}"
                                 SelectedItem="{Binding SelectedArtist}"
                                 DoubleTapped="ArtistsList_OnDoubleTapped"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="{Binding IsArtistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Artist">
                                    <Border Padding="12" Margin="0,0,0,10" Background="#16FFFFFF" CornerRadius="16">
                                        <Grid ColumnDefinitions="64,*,100" ColumnSpacing="12">
                                            <Border Grid.Column="0" Width="52" Height="52" Background="#1DFFFFFF" CornerRadius="26">
                                                <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#FFF7F8FB"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="艺术家"
                                                           Foreground="#AEBACE"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AlbumCount}"
                                                       Foreground="#FFF7F8FB"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Playlists}"
                                 SelectedItem="{Binding SelectedPlaylist}"
                                 DoubleTapped="PlaylistsList_OnDoubleTapped"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="{Binding IsPlaylistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Playlist">
                                    <Border Padding="12" Margin="0,0,0,10" Background="#16FFFFFF" CornerRadius="16">
                                        <Grid ColumnDefinitions="64,*,110,110" ColumnSpacing="12">
                                            <Border Grid.Column="0" Width="52" Height="52" Background="#1DFFFFFF" CornerRadius="14">
                                                <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#FFF7F8FB"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="播放列表"
                                                           Foreground="#AEBACE"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SongCount, StringFormat='{}{0} 首歌曲'}"
                                                       Foreground="#AEBACE"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DurationText}"
                                                       Foreground="#FFF7F8FB"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid IsVisible="{Binding IsNowPlayingView}" ColumnDefinitions="340,*" ColumnSpacing="28">
                            <Border Background="#16FFFFFF" CornerRadius="24" Padding="22">
                                <StackPanel Spacing="18">
                                    <Border Height="296" Background="#1DFFFFFF" CornerRadius="22">
                                        <Image Source="{Binding CurrentSong.CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding CurrentSong.Title, FallbackValue=未播放}"
                                                   Foreground="#FFF7F8FB"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding CurrentSongSubtitle}"
                                                   Foreground="#AEBACE"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="24" Padding="22">
                                <ScrollViewer>
                                    <TextBlock Text="{Binding CurrentSongLyrics}"
                                               Foreground="#DCE3ED"
                                               FontSize="16"
                                               LineHeight="30"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <ScrollViewer IsVisible="{Binding IsSettingsView}">
                            <StackPanel Spacing="18">
                                <Border Background="#16FFFFFF" CornerRadius="22" Padding="18">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                            <TextBlock Text="{Binding ConnectionFormTitle}"
                                                       Foreground="#FFF7F8FB"
                                                       FontWeight="Bold"
                                                       FontSize="20" />
                                            <TextBlock Grid.Column="1"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding ConnectionFormHint}"
                                                       Foreground="#AEBACE"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="180,*,160,160"
                                              ColumnSpacing="12"
                                              RowDefinitions="Auto,Auto">
                                            <TextBox Grid.Column="0" Grid.Row="0" PlaceholderText="配置名称" Text="{Binding ServerProfileName}" />
                                            <TextBox Grid.Column="1" Grid.Row="0" PlaceholderText="服务器地址" Text="{Binding ServerUrl}" />
                                            <TextBox Grid.Column="2" Grid.Row="0" PlaceholderText="用户名" Text="{Binding Username}" />
                                            <TextBox Grid.Column="3" Grid.Row="0" PlaceholderText="密码" PasswordChar="*" Text="{Binding Password}" />
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="4"
                                                       Text="需要先验证服务器时，可以点击“测试连接”；确认无误后点击“保存并启用”。"
                                                       Foreground="#AEBACE"
                                                       FontSize="12" />
                                        </Grid>
                                        <WrapPanel Grid.Row="2" Orientation="Horizontal">
                                            <Button Content="新建空白配置" Command="{Binding NewServerCommand}" Margin="0,0,8,8" />
                                            <Button Content="编辑选中" Command="{Binding EditSelectedServerCommand}" IsEnabled="{Binding HasSelectedSavedServer}" Margin="0,0,8,8" />
                                            <Button Content="取消编辑" Command="{Binding CancelServerEditCommand}" Margin="0,0,8,8" />
                                            <Button Content="{Binding SaveServerButtonText}" Command="{Binding SaveCurrentServerCommand}" Margin="0,0,8,8" />
                                            <Button Content="测试连接" Command="{Binding TestConnectionCommand}" Margin="0,0,8,8" />
                                            <Button Content="清空保存数据" Command="{Binding ClearSavedConnectionCommand}" Margin="0,0,8,8" />
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#16FFFFFF" CornerRadius="22" Padding="18">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="封面缓存"
                                                       Foreground="#FFF7F8FB"
                                                       FontWeight="Bold"
                                                       FontSize="18" />
                                            <TextBlock Text="{Binding CoverArtCacheDirectory}"
                                                       Foreground="#AEBACE"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="清理缓存"
                                                Command="{Binding ClearCoverArtCacheCommand}"
                                                VerticalAlignment="Top" />
                                    </Grid>
                                </Border>

                                <Border Background="#16FFFFFF" CornerRadius="22" Padding="18">
                                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                        <TextBlock Text="已保存服务器"
                                                   Foreground="#FFF7F8FB"
                                                   FontWeight="Bold"
                                                   FontSize="18" />
                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <ListBox ItemsSource="{Binding SavedServers}"
                                                     SelectedItem="{Binding SelectedSavedServer}"
                                                     Background="Transparent"
                                                     BorderThickness="0">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SavedServerProfile">
                                                        <Border Padding="12" Margin="0,0,0,8" Background="#12FFFFFF" CornerRadius="14">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           Foreground="#FFF7F8FB"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding ServerUrl}"
                                                                           Foreground="#AEBACE"
                                                                           FontSize="12"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Button Grid.Column="1"
                                                    Content="启用"
                                                    Command="{Binding UseSelectedServerCommand}"
                                                    IsEnabled="{Binding HasSelectedSavedServer}"
                                                    VerticalAlignment="Top" />
                                            <Button Grid.Column="2"
                                                    Content="删除"
                                                    Command="{Binding RemoveSelectedServerCommand}"
                                                    IsEnabled="{Binding HasSelectedSavedServer}"
                                                    VerticalAlignment="Top" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#12FFFFFF" CornerRadius="24" Padding="18">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Text="{Binding SidebarTitle}"
                                   Foreground="#FFF7F8FB"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="队列"
                                Command="{Binding ShowQueueSidebarCommand}" />
                        <Button Grid.Column="2"
                                Content="最近"
                                Command="{Binding ShowRecentSidebarCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" IsVisible="{Binding IsQueueSidebar}">
                        <TextBlock Text="管理当前播放队列"
                                   Foreground="#AEBACE"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="移除"
                                Command="{Binding RemoveSelectedFromQueueCommand}" />
                        <Button Grid.Column="2"
                                Content="清空"
                                Command="{Binding ClearQueueCommand}" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding PlaybackQueue}"
                             SelectedItem="{Binding SelectedSong}"
                             DoubleTapped="SongsList_OnDoubleTapped"
                             Background="Transparent"
                             BorderThickness="0"
                             IsVisible="{Binding IsQueueSidebar}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Border Padding="10" Margin="0,0,0,8" Background="#14FFFFFF" CornerRadius="14">
                                    <Grid ColumnDefinitions="48,*" ColumnSpacing="12">
                                        <Border Width="48" Height="48" Background="#1DFFFFFF" CornerRadius="12">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#FFF7F8FB"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="#AEBACE"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecentlyPlayed}"
                             SelectedItem="{Binding SelectedSong}"
                             DoubleTapped="SongsList_OnDoubleTapped"
                             Background="Transparent"
                             BorderThickness="0"
                             IsVisible="{Binding IsRecentSidebar}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Border Padding="10" Margin="0,0,0,8" Background="#14FFFFFF" CornerRadius="14">
                                    <Grid ColumnDefinitions="48,*" ColumnSpacing="12">
                                        <Border Width="48" Height="48" Background="#1DFFFFFF" CornerRadius="12">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#FFF7F8FB"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="#AEBACE"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="20,0,20,20" Padding="18,14" Background="#18FFFFFF" CornerRadius="22">
            <Grid ColumnDefinitions="280,*,280" ColumnSpacing="18">
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding OpenNowPlayingDetailsCommand}">
                    <Grid ColumnDefinitions="62,*" ColumnSpacing="12">
                        <Border Width="58" Height="58" Background="#1DFFFFFF" CornerRadius="16">
                            <Image Source="{Binding CurrentSong.CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                   Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding CurrentSong.Title, FallbackValue=未播放}"
                                       Foreground="#FFF7F8FB"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentSongSubtitle}"
                                       Foreground="#AEBACE"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Button>

                <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding PlaybackPositionText}"
                                   Foreground="#AEBACE"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding PlaybackDuration}"
                                Value="{Binding PlaybackPosition}"
                                IsEnabled="{Binding CanSeek}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PlaybackDurationText}"
                                   Foreground="#AEBACE"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Center" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Width="42"
                                Height="36"
                                Command="{Binding PlayPreviousCommand}"
                                ToolTip.Tip="上一首">
                            <Path Width="18"
                                  Height="18"
                                  Data="M 4 4 L 7 4 L 7 20 L 4 20 Z M 19 5 L 9 12 L 19 19 Z"
                                  Fill="#FFF7F8FB"
                                  Stretch="Uniform" />
                        </Button>
                        <Button Grid.Column="1"
                                Width="46"
                                Height="40"
                                Command="{Binding PlaySelectedCommand}"
                                ToolTip.Tip="播放选中歌曲">
                            <Path Width="18"
                                  Height="18"
                                  Data="M 6 4 L 20 12 L 6 20 Z"
                                  Fill="#FFF7F8FB"
                                  Stretch="Uniform" />
                        </Button>
                        <Button Grid.Column="2"
                                Width="42"
                                Height="36"
                                Command="{Binding TogglePlaybackCommand}"
                                ToolTip.Tip="{Binding PlaybackToggleToolTip}">
                            <Path Width="18"
                                  Height="18"
                                  Data="M 6 4 L 10 4 L 10 20 L 6 20 Z M 14 4 L 18 4 L 18 20 L 14 20 Z"
                                  Fill="#FFF7F8FB"
                                  Stretch="Uniform" />
                        </Button>
                        <Button Grid.Column="3"
                                Width="42"
                                Height="36"
                                Command="{Binding StopCommand}"
                                ToolTip.Tip="停止">
                            <Path Width="16"
                                  Height="16"
                                  Data="M 5 5 L 19 5 L 19 19 L 5 19 Z"
                                  Fill="#FFF7F8FB"
                                  Stretch="Uniform" />
                        </Button>
                        <Button Grid.Column="4"
                                Width="42"
                                Height="36"
                                Command="{Binding PlayNextCommand}"
                                ToolTip.Tip="下一首">
                            <Path Width="18"
                                  Height="18"
                                  Data="M 5 5 L 15 12 L 5 19 Z M 17 4 L 20 4 L 20 20 L 17 20 Z"
                                  Fill="#FFF7F8FB"
                                  Stretch="Uniform" />
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="音量"
                               Foreground="#AEBACE"
                               FontSize="12" />
                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</suki:SukiWindow>
