<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VmeMusic.ViewModels"
        xmlns:models="using:VmeMusic.Models"
        xmlns:converters="using:VmeMusic.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="VmeMusic.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="VmeMusic"
        Width="1180"
        Height="760"
        MinWidth="940"
        MinHeight="620">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <converters:CoverArtConverter x:Key="CoverArtConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Background="#101214">
        <Border Grid.Row="0" Background="#181B1F" Padding="18,14">
            <Grid ColumnDefinitions="220,180,180,Auto,Auto,*,Auto" ColumnSpacing="10">
                <TextBox Grid.Column="0"
                         PlaceholderText="Server URL"
                         Text="{Binding ServerUrl}" />
                <TextBox Grid.Column="1"
                         PlaceholderText="Username"
                         Text="{Binding Username}" />
                <TextBox Grid.Column="2"
                         PlaceholderText="Password"
                         PasswordChar="*"
                         Text="{Binding Password}" />
                <Button Grid.Column="3"
                        Content="Test"
                        Command="{Binding TestConnectionCommand}" />
                <Button Grid.Column="4"
                        Content="Clear"
                        Command="{Binding ClearSavedConnectionCommand}" />
                <TextBox Grid.Column="5"
                         PlaceholderText="Search songs"
                         Text="{Binding SearchQuery}" />
                <Button Grid.Column="6"
                        Content="Search"
                        Command="{Binding SearchCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="190,*,300">
            <Border Grid.Column="0" Background="#15181B" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="VmeMusic"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7" />
                    <TextBlock Text="Search"
                               Margin="0,24,0,0"
                               Foreground="#F3F5F7"
                               FontWeight="SemiBold" />
                    <Button Content="Newest albums"
                            Command="{Binding LoadNewestAlbumsCommand}" />
                    <Button Content="Artists"
                            Command="{Binding LoadArtistsCommand}" />
                    <Button Content="Playlists"
                            Command="{Binding LoadPlaylistsCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#101214" Padding="18">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding ContentTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7"
                               Margin="0,0,0,12" />

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedSong}"
                                 DoubleTapped="SongsList_OnDoubleTapped"
                                 IsVisible="{Binding IsSongsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Grid ColumnDefinitions="56,*,170,170,70" Margin="0,6">
                                        <Border Grid.Column="0"
                                                Width="42"
                                                Height="42"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Artist}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Album}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DurationSeconds}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Albums}"
                                 SelectedItem="{Binding SelectedAlbum}"
                                 DoubleTapped="AlbumsList_OnDoubleTapped"
                                 IsVisible="{Binding IsAlbumsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Album">
                                    <Grid ColumnDefinitions="64,*,180,70,70" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Artist}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Year}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding SongCount}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Artists}"
                                 SelectedItem="{Binding SelectedArtist}"
                                 DoubleTapped="ArtistsList_OnDoubleTapped"
                                 IsVisible="{Binding IsArtistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Artist">
                                    <Grid ColumnDefinitions="64,*,100" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="24">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AlbumCount}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding Playlists}"
                                 SelectedItem="{Binding SelectedPlaylist}"
                                 DoubleTapped="PlaylistsList_OnDoubleTapped"
                                 IsVisible="{Binding IsPlaylistsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Playlist">
                                    <Grid ColumnDefinitions="64,*,100,100" Margin="0,7">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Background="#242A30"
                                                CornerRadius="4">
                                            <Image Source="{Binding CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#F3F5F7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SongCount}"
                                                   Foreground="#B8C0CC"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DurationSeconds}"
                                                   Foreground="#8E98A7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#15181B" Padding="18">
                <Grid RowDefinitions="Auto,Auto,Auto,196,Auto,*">
                    <TextBlock Text="Now Playing"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F3F5F7" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding CurrentSong.Title, FallbackValue=Nothing playing}"
                               Foreground="#F3F5F7"
                               FontSize="16"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding CurrentSong.Artist}"
                               Foreground="#9CA3AF"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                    <Border Grid.Row="3"
                            Width="180"
                            Height="180"
                            HorizontalAlignment="Left"
                            Background="#242A30"
                            CornerRadius="6"
                            Margin="0,20,0,8">
                        <Image Source="{Binding CurrentSong.CoverArtUrl, Converter={StaticResource CoverArtConverter}}"
                               Stretch="UniformToFill" />
                    </Border>
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,4,0,10">
                        <TextBlock Grid.Column="0"
                                   Text="Queue"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F5F7"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Remove"
                                Command="{Binding RemoveSelectedFromQueueCommand}" />
                        <Button Grid.Column="2"
                                Content="Clear"
                                Command="{Binding ClearQueueCommand}" />
                    </Grid>
                    <ListBox Grid.Row="5"
                             ItemsSource="{Binding PlaybackQueue}"
                             SelectedItem="{Binding SelectedSong}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <StackPanel Margin="0,5">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#F3F5F7"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Artist}"
                                               Foreground="#8E98A7"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#181B1F" Padding="18,12">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,2*,Auto,Auto,120" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#B8C0CC"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1"
                        Content="Prev"
                        Command="{Binding PlayPreviousCommand}" />
                <Button Grid.Column="2"
                        Content="Play"
                        Command="{Binding PlaySelectedCommand}" />
                <Button Grid.Column="3"
                        Content="Pause"
                        Command="{Binding TogglePlaybackCommand}" />
                <Button Grid.Column="4"
                        Content="Stop"
                        Command="{Binding StopCommand}" />
                <Button Grid.Column="5"
                        Content="Next"
                        Command="{Binding PlayNextCommand}" />
                <Slider Grid.Column="6"
                        Minimum="0"
                        Maximum="{Binding PlaybackDuration}"
                        Value="{Binding PlaybackPosition}"
                        IsEnabled="False"
                        VerticalAlignment="Center" />
                <TextBlock Grid.Column="7"
                           Text="{Binding PlaybackPositionText}"
                           Foreground="#B8C0CC"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="8"
                           Text="{Binding PlaybackDurationText}"
                           Foreground="#8E98A7"
                           VerticalAlignment="Center" />
                <Slider Grid.Column="9"
                        Minimum="0"
                        Maximum="100"
                        Value="{Binding Volume}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>

</Window>
